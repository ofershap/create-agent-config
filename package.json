{
  "name": "create-agent-config",
  "version": "2.0.0",
  "description": "Scaffold AI agent config files for any project. Detects your stack, pulls community rules from cursor.directory, writes configs for Cursor, Claude Code, Copilot, Windsurf, Cline, and AGENTS.md.",
  "type": "module",
  "bin": {
    "create-agent-config": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]"
        }
      ]
    ]
  },
  "keywords": [
    "agent-config",
    "agents-md",
    "claude-md",
    "cursor-rules",
    "cursorrules",
    "copilot-instructions",
    "windsurf",
    "ai-agent",
    "scaffolding",
    "generator",
    "create",
    "ai-context",
    "coding-agent",
    "claude-code",
    "ai-rules",
    "cline",
    "vibe-coding",
    "cursor-directory",
    "community-rules"
  ],
  "author": "Ofer Shapira <ofer@ofershap.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ofershap/create-agent-config.git"
  },
  "bugs": {
    "url": "https://github.com/ofershap/create-agent-config/issues"
  },
  "homepage": "https://github.com/ofershap/create-agent-config#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.5.3",
    "semantic-release": "^25.0.3",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.25.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "picocolors": "^1.1.1"
  }
}
